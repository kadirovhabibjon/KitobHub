# Project
PROJECT_NAME=KitobHub
ENVIRONMENT=local

# PostgreSQL
POSTGRES_USER=kitobhub
POSTGRES_PASSWORD=kitobhub_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

CATALOG_DB_NAME=catalog_db
ORDER_DB_NAME=order_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ORDER_CREATED_TOPIC=order.created

# Services internal URLs
CATALOG_SERVICE_URL=http://catalog-service:8000
ORDER_SERVICE_URL=http://order-service:8000
TOOLS_SERVICE_URL=http://tools-service:8000

# External APIs
OPEN_METEO_BASE_URL=https://api.open-meteo.com
FRANKFURTER_BASE_URL=https://api.frankfurter.app

# Frontend
VITE_API_BASE_URL=/api
